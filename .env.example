# 生产或公开部署时必须改成足够长的随机字符串。
ZONGCE_SECRET_KEY=replace-with-a-long-random-secret

# 可选：默认数据库位于 app.py 同目录的 zongce.db。
# ZONGCE_DATABASE_URL=sqlite:///D:/path/to/zongce.db

# 可选：逗号分隔的前端来源。
ZONGCE_CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# 可选：默认上传目录为 app.py 同目录下的 uploads。
# ZONGCE_UPLOAD_DIR=D:/path/to/uploads

# AI材料辅助核验（密钥只放在本机 .env，绝不能提交到版本库）。
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# 可选：1 表示启用AI入口；0 可在保留配置的同时关闭AI功能。
ZONGCE_AI_ENABLED=1
